{
  "permissions": {
    "allow": [
      "Edit(**)",
      "Read(**)",
      "Write(**)",
      "Agent(**)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/bootstrap-rin.sh"
          }
        ]
      }
    ]
  }
}
